#!/usr/bin/env python3
# -*- coding: utf-8 -*-
import logging
import sys
from logging.handlers import SysLogHandler

from wb.mqtt_alice.cli.main import main
from wb.mqtt_alice.common.constants import WB_MQTT_ALICE_CLI_LOGGER_NAME

handler = SysLogHandler(address='/dev/log', facility=SysLogHandler.LOG_USER)
# use logger name as prefix — journald recognizes it as SYSLOG_IDENTIFIER
formatter = logging.Formatter('%(name)s: %(message)s')
handler.setFormatter(formatter)

root_logger = logging.getLogger()
root_logger.setLevel(logging.INFO)
if not any(isinstance(h, SysLogHandler) for h in root_logger.handlers):
    root_logger.addHandler(handler)

logger = logging.getLogger(WB_MQTT_ALICE_CLI_LOGGER_NAME)
logger.setLevel(logging.INFO)

if __name__ == "__main__":
    sys.exit(main())
